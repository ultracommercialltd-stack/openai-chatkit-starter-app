# LoveGenie ChatKit adapter — the server proxies to the locked Love-Genie backend.
# No OPENAI_API_KEY is needed: the LLM lives in Love-Genie.

# Base URL of the Love-Genie Node/Vercel backend (dev: `vercel dev --listen 4310`).
LOVEGENIE_API_BASE=http://127.0.0.1:4310

# Supabase (optional): JWT secret is used only for best-effort user-id decode.
# Love-Genie remains the source of truth for auth + entitlement.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# CORS: comma-separated origins allowed to call /chatkit (the LoveGenieApp host).
CHATKIT_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173

# Frontend (starter demo) — point the web component at this backend.
VITE_CHATKIT_API_URL=http://127.0.0.1:8000/chatkit
VITE_CHATKIT_API_DOMAIN_KEY=domain_pk_local_dev
